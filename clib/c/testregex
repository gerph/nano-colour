#include <stdio.h>
#include <stdlib.h>
#include "RegEx/regex.h"

void test(const char *pat, const char *str) {
    regex_t re;
    int err = regcomp(&re, pat, REG_EXTENDED);
    if (err) {
        char buf[256];
        regerror(err, &re, buf, sizeof(buf));
        printf("Pattern '%s' failed to compile: %s\n", pat, buf);
        return;
    }
    if (regexec(&re, str, 0, NULL, 0) == 0) {
        printf("Pattern '%s' matched '%s'\n", pat, str);
    } else {
        printf("Pattern '%s' DID NOT match '%s'\n", pat, str);
    }
    regfree(&re);
}

int main() {
    const char *str = "void test";
    test("\\<void\\>", str);
    test("[[:<:]]void[[:>:]]", str);
    test("\\bvoid\\b", str);
    test("void", str);
    return 0;
}
