int my_strcasecmp(const char *s1, const char *s2) {
    while (*s1 && (tolower(*s1) == tolower(*s2))) {
        s1++; s2++;
    }
    return tolower(*(unsigned char *)s1) - tolower(*(unsigned char *)s2);
}

int my_strncasecmp(const char *s1, const char *s2, size_t n) {
    if (n == 0) return 0;
    while (n-- > 0 && *s1 && (tolower(*s1) == tolower(*s2))) {
        if (n == 0 || !*s1) break;
        s1++; s2++;
    }
    return tolower(*(unsigned char *)s1) - tolower(*(unsigned char *)s2);
}

char *my_strdup(const char *s) {
    size_t len = strlen(s) + 1;
    char *res = malloc(len);
    if (res) memcpy(res, s, len);
    return res;
}

static Colour name_to_colour(const char *name) {
    if (my_strcasecmp(name, "black") == 0) return COLOUR_BLACK;
    if (my_strcasecmp(name, "red") == 0) return COLOUR_RED;
    if (my_strcasecmp(name, "green") == 0) return COLOUR_GREEN;
    if (my_strcasecmp(name, "yellow") == 0) return COLOUR_YELLOW;
    if (my_strcasecmp(name, "blue") == 0) return COLOUR_BLUE;
    if (my_strcasecmp(name, "magenta") == 0) return COLOUR_MAGENTA;
    if (my_strcasecmp(name, "cyan") == 0) return COLOUR_CYAN;
    if (my_strcasecmp(name, "white") == 0) return COLOUR_WHITE;
    if (my_strcasecmp(name, "normal") == 0) return COLOUR_NORMAL;
    return COLOUR_NORMAL;
}

static Style parse_style(const char *colors_str) {
    Style s;
    char *buf;
    char *comma;
    char *fg;
    char *bg = NULL;

    s.fg = COLOUR_NORMAL;
    s.bg = COLOUR_NORMAL;
    s.bright = 0;

    buf = my_strdup(colors_str);
    if (!buf) return s;

    comma = strchr(buf, ',');
    fg = buf;

    if (comma) {
        *comma = '\0';
        bg = comma + 1;
    }

    if (my_strncasecmp(fg, "bright", 6) == 0) {
        s.bright = 1;
        fg += 6;
    }

    s.fg = name_to_colour(fg);
    if (bg) {
        s.bg = name_to_colour(bg);
    }

    free(buf);
    return s;
}

static char *extract_quoted(char **ptr) {
    char *s = *ptr;
    char *start;
    char *res;
    char *d;
    char *src;

    while (*s && isspace(*s)) s++;
    if (*s != '"') {
        start = s;
        while (*s && !isspace(*s)) s++;
        if (*s) {
            *s = '\0';
            *ptr = s + 1;
        } else {
            *ptr = s;
        }
        return my_strdup(start);
    }
    s++;
    start = s;
    while (*s) {
        if (*s == '"' &&
            !(s > start && *(s - 1) == '\\') &&
            (s[1] == '\0' || isspace((unsigned char)s[1]))) {
            break;
        }
        s++;
    }
    if (*s == '"') {
        *s = '\0';
        *ptr = s + 1;
    } else {
        *ptr = s;
    }
    res = my_strdup(start);
    if (!res) return NULL;
    d = res;
    src = res;
    while (*src) {
        if (*src == '\\' && *(src+1) == '"') {
            src++;
        }
        *d++ = *src++;
    }
    *d = '\0';
    return res;
}

static char *fix_regex(char *re) {
    char *new_re = malloc(strlen(re) * 7 + 1);
    char *d = new_re;
    char *s = re;
    int in_class = 0;
    while (*s) {
        if (*s == '[') {
            in_class = 1;
            *d++ = *s++;
        } else if (*s == ']' && in_class) {
            in_class = 0;
            *d++ = *s++;
        } else if (!in_class &&
                   ((*s == '*' || *s == '+' || *s == '?') && *(s + 1) == '?')) {
            *d++ = *s++;
            s++;
        } else if (*s == '\\' && *(s+1) == '<') {
            *d++ = '['; *d++ = '['; *d++ = ':'; *d++ = '<'; *d++ = ':'; *d++ = ']'; *d++ = ']';
            s += 2;
        } else if (*s == '\\' && *(s+1) == '>') {
            *d++ = '['; *d++ = '['; *d++ = ':'; *d++ = '>'; *d++ = ':'; *d++ = ']'; *d++ = ']';
            s += 2;
        } else {
            *d++ = *s++;
        }
    }
    *d = '\0';
    free(re);
    return new_re;
}

static NanoStatus append_regex(char **dest, const char *re) {
    char *dup;
    char *fixed;

    dup = my_strdup(re);
    if (!dup) return NANO_ERROR_NOMEM;

    fixed = fix_regex(dup);
    if (!fixed) return NANO_ERROR_NOMEM;

    if (*dest == NULL) {
        *dest = fixed;
    } else {
        size_t old_len;
        size_t new_len;
        char *combined;

        old_len = strlen(*dest);
        new_len = strlen(fixed);
        combined = malloc(old_len + new_len + 5);
        if (!combined) {
            free(fixed);
            return NANO_ERROR_NOMEM;
        }
        sprintf(combined, "(%s)|(%s)", *dest, fixed);
        free(*dest);
        free(fixed);
        *dest = combined;
    }

    return NANO_OK;
}

NanoStatus nanocolour_get_syntax_info(const char *filename, SyntaxInfo *info) {
    FILE *f;
    char line[4096];
    NanoStatus status;

    if (!info) return NANO_ERROR_INVALID_ARG;

    info->name = NULL;
    info->syntax_regex = NULL;
    info->magic_regex = NULL;

    f = fopen(filename, "r");
    if (!f) {
        return NANO_ERROR_FILE;
    }

    status = NANO_OK;

    while (fgets(line, sizeof(line), f)) {
        char *p;

        p = line;
        while (*p && isspace(*p)) p++;
        if (*p == '#' || *p == '\0') continue;

        if (strncmp(p, "syntax", 6) == 0 && isspace(p[6])) {
            char *name;

            p += 7;
            name = extract_quoted(&p);
            if (!name) {
                status = NANO_ERROR_NOMEM;
                break;
            }
            free(info->name);
            info->name = name;

            while (*p) {
                char *re;

                while (*p && isspace(*p)) p++;
                if (!*p) break;

                re = extract_quoted(&p);
                if (!re) {
                    status = NANO_ERROR_NOMEM;
                    break;
                }
                if (*re) {
                    status = append_regex(&info->syntax_regex, re);
                }
                free(re);
                if (status != NANO_OK) break;
            }
            if (status != NANO_OK) break;
        } else if (strncmp(p, "header", 6) == 0 && isspace(p[6])) {
            p += 7;

            while (*p) {
                char *re;

                while (*p && isspace(*p)) p++;
                if (!*p) break;

                re = extract_quoted(&p);
                if (!re) {
                    status = NANO_ERROR_NOMEM;
                    break;
                }
                if (*re) {
                    status = append_regex(&info->magic_regex, re);
                }
                free(re);
                if (status != NANO_OK) break;
            }
            if (status != NANO_OK) break;
        }
    }

    fclose(f);

    if (status != NANO_OK) {
        free(info->name);
        free(info->syntax_regex);
        free(info->magic_regex);
        info->name = NULL;
        info->syntax_regex = NULL;
        info->magic_regex = NULL;
    }

    return status;
}

NanoStatus nanocolour_parse_rc(const char *filename, Syntax **syntax_out) {
    FILE *f;
    SyntaxInternal *si;
    char line[4096];
    NanoStatus status = NANO_OK;

    if (!syntax_out) return NANO_ERROR_INVALID_ARG;
    *syntax_out = NULL;

    dprintf("Reading '%s'\n", filename);
    f = fopen(filename, "r");
    if (!f)
    {
        dprintf("Could not open file '%s'\n", filename);
        return NANO_ERROR_FILE;
    }

    si = calloc(1, sizeof(SyntaxInternal));
    if (!si) {
        dprintf("No memory\n");
        fclose(f);
        return NANO_ERROR_NOMEM;
    }

    while (fgets(line, sizeof(line), f)) {
        char *p = line;
        while (*p && isspace(*p)) p++;
        if (*p == '#' || *p == '\0') continue;
        dprintf("Read line '%s'\n", p);

        if (strncmp(p, "syntax", 6) == 0 && isspace(p[6])) {
            p += 7;
            free(si->name);
            si->name = extract_quoted(&p);
            if (!si->name) { status = NANO_ERROR_NOMEM; break; }
        } else if ((strncmp(p, "color", 5) == 0 && isspace(p[5])) ||
                   (strncmp(p, "icolor", 6) == 0 && isspace(p[6]))) {
            int icase = (*p == 'i');
            char *colors_str;
            Style style;

            p += (icase ? 7 : 6);
            while (*p && isspace(*p)) p++;
            colors_str = p;
            while (*p && !isspace(*p)) p++;
            if (*p) {
                *p = '\0';
                p++;
            }
            style = parse_style(colors_str);

            while (*p && isspace(*p)) p++;
            if (strncmp(p, "start=", 6) == 0) {
                p += 6;
                {
                    char *start_re = extract_quoted(&p);
                    if (!start_re) { status = NANO_ERROR_NOMEM; break; }
                    while (*p && isspace(*p)) p++;
                    if (strncmp(p, "end=", 4) == 0) {
                        p += 4;
                        {
                            char *end_re = extract_quoted(&p);
                            char *f_start, *f_end;
                            SyntaxRuleInternal *r;
                            SyntaxRuleInternal *new_rules;
                            
                            if (!end_re) { free(start_re); status = NANO_ERROR_NOMEM; break; }
                            
                            new_rules = realloc(si->rules, (si->rule_count + 1) * sizeof(SyntaxRuleInternal));
                            if (!new_rules) { free(start_re); free(end_re); status = NANO_ERROR_NOMEM; break; }
                            si->rules = new_rules;
                            r = &si->rules[si->rule_count];
                            r->type = RULE_MULTI;
                            r->style = style;
                            r->icase = icase;
                            
                            f_start = fix_regex(start_re);
                            f_end = fix_regex(end_re);
                            
                            {
                                int err;
                                static char errbuf[256];
                                err = regcomp(&r->re_start, f_start, REG_EXTENDED | (icase ? REG_ICASE : 0));
                                if (err) {
                                    regerror(err, &r->re_start, errbuf, sizeof(errbuf));
                                    dprintf("regcomp start failed for '%s': %s\n", f_start, errbuf);
                                    free(f_start); free(f_end);
                                    status = NANO_ERROR_REGEX; break;
                                }
                                err = regcomp(&r->re_end, f_end, REG_EXTENDED | (icase ? REG_ICASE : 0));
                                if (err) {
                                    regerror(err, &r->re_end, errbuf, sizeof(errbuf));
                                    dprintf("regcomp end failed for '%s': %s\n", f_end, errbuf);
                                    regfree(&r->re_start);
                                    free(f_start); free(f_end);
                                    status = NANO_ERROR_REGEX; break;
                                }
                            }
                            free(f_start);
                            free(f_end);
                            si->rule_count++;
                        }
                    } else {
                        free(start_re);
                    }
                }
            } else {
                while (*p) {
                    char *re;
                    while (*p && isspace(*p)) p++;
                    if (!*p) break;
                    re = extract_quoted(&p);
                    if (!re) { status = NANO_ERROR_NOMEM; break; }
                    if (*re) {
                        char *f_re;
                        SyntaxRuleInternal *r;
                        SyntaxRuleInternal *new_rules;
                        
                        new_rules = realloc(si->rules, (si->rule_count + 1) * sizeof(SyntaxRuleInternal));
                        if (!new_rules) { free(re); status = NANO_ERROR_NOMEM; break; }
                        si->rules = new_rules;
                        r = &si->rules[si->rule_count];
                        r->type = RULE_SINGLE;
                        r->style = style;
                        r->icase = icase;
                        
                        f_re = fix_regex(re);
                        {
                            int err;
                            static char errbuf[256];
                            err = regcomp(&r->re_start, f_re, REG_EXTENDED | (icase ? REG_ICASE : 0));
                            if (err) {
                                regerror(err, &r->re_start, errbuf, sizeof(errbuf));
                                dprintf("regcomp failed for '%s': %s\n", f_re, errbuf);
                                free(f_re);
                                status = NANO_ERROR_REGEX; break;
                            }
                        }
                        free(f_re);
                        si->rule_count++;
                    } else {
                        free(re);
                    }
                }
                if (status != NANO_OK) break;
            }
        }
    }
    fclose(f);
    if (status != NANO_OK) {
        dprintf("Exited with a failure: %i\n", status);
        nanocolour_free_syntax((Syntax *)si);
        return status;
    }
    dprintf("Opened and read file OK\n");
    *syntax_out = (Syntax *)si;
    return NANO_OK;
}

void nanocolour_free_syntax(Syntax *syntax) {
    size_t i;
    SyntaxInternal *si;
    if (!syntax) return;
    si = (SyntaxInternal *)syntax;
    free(si->name);
    for (i = 0; i < si->rule_count; i++) {
        regfree(&si->rules[i].re_start);
        if (si->rules[i].type == RULE_MULTI) {
            regfree(&si->rules[i].re_end);
        }
    }
    free(si->rules);
    free(si);
}
