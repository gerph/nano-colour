#include <assert.h>
#include <stdlib.h>
#include <stdio.h>

#include "swis.h"

#include "GContext/gcontext.h"

#include "VersionNum"

#define FONT_NAME "Corpus.Medium"
#define FONT_XSIZE (12*16)
#define FONT_YSIZE (12*16)

void testgcontext(void)
{
    gcontext_t *gcontext = gcontext_initvdu(2);

    gcontext->rectangle_fill(gcontext, 0x81397900, 64, 64, 500,500);

    {
        stringbounds_t bounds;
        int width;
        char *text = "HELLO THERE!";
        int textlen = 5;
        int xoffset;

        font_t font = gcontext->text_findfont(gcontext, FONT_NAME, FONT_XSIZE, FONT_YSIZE);

        gcontext->text_getstringsize(gcontext, font,
                                     &bounds, 0x7FFFFFFF,
                                     text, textlen, GCONTEXT_NOSPLIT);

        width = bounds.rbearing;
        xoffset  = bounds.xoffset;

        gcontext->text_paint(gcontext, font,
                             64, 800, COLOUR_RGB(0,0,0), COLOUR_RGB(255,255,255),
                             text, textlen);

        gcontext->line_start(gcontext, 0xFF000000);
        gcontext->line_line(gcontext, 64, 800, 64+xoffset, 800);
        gcontext->line_line(gcontext, 64, 792, 64+width, 792);
        gcontext->line_end(gcontext);
    }

    exit(EXIT_SUCCESS);
}
