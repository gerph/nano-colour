gcontext_t *global_gc = NULL;

static _kernel_oserror *status_to_oserror(NanoStatus status) {
    switch (status) {
        case NANO_OK: return NULL;
        case NANO_ERROR_NOMEM: return err_NoMemory;
        case NANO_ERROR_FILE: return err_FileError;
        case NANO_ERROR_REGEX: return err_RegexError;
        case NANO_ERROR_INVALID_ARG: return err_InvalidArg;
        default: return err_InternalError;
    }
}

static _kernel_oserror *do_todrawbuffer(void *buffer, size_t *buf_len, const char *src_path, const char *rc_path,
                                        const char *font_name, int font_x, int font_y,
                                        uint32_t bg_col, uint32_t fg_col) {
    ColouredFile *cf;
    char *contents;
    size_t length;
    Syntax *syntax;
    NanoStatus status;
    _kernel_oserror *err;
    int is_auto = 0;

    if (rc_path != NULL && rc_path[0] != '\0') {
        status = nanocolour_parse_rc(rc_path, &syntax);
    } else {
        err = syntax_find_for_file(src_path, &syntax);
        status = (err == NULL) ? NANO_OK : NANO_ERROR_FILE;
        is_auto = 1;
    }
    if (status != NANO_OK) return status_to_oserror(status);

    status = nanocolour_read_file(src_path, &contents, &length);
    if (status != NANO_OK) {
        if (!is_auto) nanocolour_free_syntax(syntax);
        return status_to_oserror(status);
    }

    status = nanocolour_colour_file(contents, length, syntax, &cf);
    if (!is_auto) nanocolour_free_syntax(syntax);
    if (status != NANO_OK) {
        free(contents);
        return status_to_oserror(status);
    }

    err = drawfile_generate(cf, font_name, font_x, font_y, bg_col, fg_col, buffer, buf_len);
    nanocolour_free_coloured_file(cf);
    free(contents);

    return err;
}

_kernel_oserror *Mod_Init(const char *tail, int podule_base, void *pw) {
    global_gc = gcontext_initvdu(2);
    if (!global_gc) return err_NoMemory;
    return NULL;
}

_kernel_oserror *Mod_Final(int fatal, int podule_base, void *pw) {
    handle_free_all();
    syntax_cache_final();
    return NULL;
}

_kernel_oserror *Mod_SWI(int swi, _kernel_swi_regs *r, void *pw) {
    switch (swi) {
        case NanoColour_ParseRC - NanoColour_00: {
            Syntax *syntax;
            NanoStatus status = nanocolour_parse_rc((char *)r->r[0], &syntax);
            if (status != NANO_OK) return status_to_oserror(status);
            return handle_create(HANDLE_SYNTAX, syntax, &r->r[0]);
        }
        case NanoColour_FreeSyntax - NanoColour_00:
            return handle_free(r->r[0], HANDLE_SYNTAX);

        case NanoColour_ColourFile - NanoColour_00: {
            Syntax *syntax = NULL;
            ColouredFile *cf;
            char *contents;
            size_t length;
            NanoStatus status;
            int is_auto = 0;

            if (r->r[0] != 0) {
                _kernel_oserror *err = handle_lookup(r->r[0], HANDLE_SYNTAX, (void **)&syntax);
                if (err) return err;
            } else {
                _kernel_oserror *err = syntax_find_for_file((char *)r->r[1], &syntax);
                if (err) return err;
                is_auto = 1;
            }

            status = nanocolour_read_file((char *)r->r[1], &contents, &length);
            if (status != NANO_OK) {
                return status_to_oserror(status);
            }

            status = nanocolour_colour_file(contents, length, syntax, &cf);
            if (status != NANO_OK) {
                free(contents);
                return status_to_oserror(status);
            }
            return handle_create(HANDLE_COLOURED_FILE, cf, &r->r[0]);
        }
        case NanoColour_FreeColouredFile - NanoColour_00:
            return handle_free(r->r[0], HANDLE_COLOURED_FILE);

        case NanoColour_RenderCreate - NanoColour_00: {
            ColouredFile *cf;
            NanoRender *render;
            font_t font;
            _kernel_oserror *err = handle_lookup(r->r[0], HANDLE_COLOURED_FILE, (void **)&cf);
            if (err) return err;
            font = global_gc->text_findfont(global_gc, (char *)r->r[1], r->r[2], r->r[3]);
            if (font == FONT_NONE) return err_FileError;
            render = nanocolour_render_create(cf, global_gc, font);
            if (!render) {
                global_gc->text_losefont(global_gc, font);
                return err_NoMemory;
            }
            return handle_create(HANDLE_RENDER, render, &r->r[0]);
        }

        case NanoColour_RenderFree - NanoColour_00:
            return handle_free(r->r[0], HANDLE_RENDER);

        case NanoColour_RenderGetSize - NanoColour_00: {
            NanoRender *render;
            bounds_t b;
            _kernel_oserror *err = handle_lookup(r->r[0], HANDLE_RENDER, (void **)&render);
            if (err) return err;
            nanocolour_render_get_size(render, &b);
            r->r[0] = b.width;
            r->r[1] = b.height;
            return NULL;
        }

        case NanoColour_RenderDraw - NanoColour_00: {
            NanoRender *render;
            _kernel_oserror *err = handle_lookup(r->r[0], HANDLE_RENDER, (void **)&render);
            if (err) return err;
            nanocolour_render_draw(render, r->r[1], r->r[2], (colour_t)r->r[3], (colour_t)r->r[4], (bbox_t *)r->r[5]);
            return NULL;
        }

        case NanoColour_RenderSetFont - NanoColour_00: {
            NanoRender *render;
            font_t font;
            _kernel_oserror *err = handle_lookup(r->r[0], HANDLE_RENDER, (void **)&render);
            if (err) return err;
            font = global_gc->text_findfont(global_gc, (char *)r->r[1], r->r[2], r->r[3]);
            if (font == FONT_NONE) return err_FileError;
            nanocolour_render_set_font(render, font);
            return NULL;
        }

        case NanoColour_ToDrawBuffer - NanoColour_00: {
            size_t buf_len = (size_t)r->r[1];
            _kernel_oserror *err = do_todrawbuffer((void *)r->r[0], &buf_len, (char *)r->r[2], (char *)r->r[3], (char *)r->r[4], r->r[5], r->r[6], (uint32_t)r->r[7], (uint32_t)r->r[8]);
            if (err == err_BufferOverflow) {
                r->r[1] = -(int)buf_len;
                return err;
            }
            r->r[1] = (int)buf_len;
            return err;
        }

        case NanoColour_ToDrawFile - NanoColour_00: {
            size_t buf_len = 0;
            void *buffer;
            _kernel_oserror *err;
            ColouredFile *cf;
            char *contents;
            size_t length;
            Syntax *syntax = NULL;
            int is_auto = 0;

            if (r->r[2] != 0 && *(char *)r->r[2] != '\0') {
                NanoStatus status = nanocolour_parse_rc((char *)r->r[2], &syntax);
                if (status != NANO_OK) return status_to_oserror(status);
            } else {
                err = syntax_find_for_file((char *)r->r[1], &syntax);
                if (err) return err;
                is_auto = 1;
            }

            {
                NanoStatus status = nanocolour_read_file((char *)r->r[1], &contents, &length);
                if (status != NANO_OK) {
                    if (!is_auto) nanocolour_free_syntax(syntax);
                    return status_to_oserror(status);
                }

                status = nanocolour_colour_file(contents, length, syntax, &cf);
                if (!is_auto) nanocolour_free_syntax(syntax);
                if (status != NANO_OK) {
                    free(contents);
                    return status_to_oserror(status);
                }
            }

            err = drawfile_generate(cf, (char *)r->r[3], r->r[4], r->r[5], (uint32_t)r->r[6], (uint32_t)r->r[7], NULL, &buf_len);
            if (err == err_BufferOverflow) {
                buffer = malloc(buf_len);
                if (!buffer) {
                    err = err_NoMemory;
                } else {
                    err = drawfile_generate(cf, (char *)r->r[3], r->r[4], r->r[5], (uint32_t)r->r[6], (uint32_t)r->r[7], buffer, &buf_len);
                    if (!err) {
                        FILE *f = fopen((char *)r->r[0], "wb");
                        if (f) {
                            fwrite(buffer, 1, buf_len, f);
                            fclose(f);
                            _swix(OS_File, _INR(0,2), 18, (char *)r->r[0], 0xAFF);
                        } else {
                            err = err_FileError;
                        }
                    }
                    free(buffer);
                }
            }
            nanocolour_free_coloured_file(cf);
            free(contents);
            return err;
        }

        default:
            return error_BAD_SWI;
    }
}
