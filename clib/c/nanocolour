#include "nanocolour.h"
#include "nanorc_internal.h"

typedef uint16_t PackedStyle;

#define PACK_STYLE(s) (((uint16_t)(s).fg) | (((uint16_t)(s).bg) << 4) | (((uint16_t)(s).bright) << 8))

static void unpack_style(PackedStyle p, Style *s) {
    s->fg = (Colour)(p & 0xF);
    s->bg = (Colour)((p >> 4) & 0xF);
    s->bright = (p >> 8) & 0x1;
}

typedef struct {
    ColouredElement *elements;
    size_t capacity;
    size_t used;
} ElementPool;

static int grow_pool(ElementPool *pool, size_t needed) {
    if (pool->used + needed > pool->capacity) {
        size_t new_cap = pool->capacity ? pool->capacity * 2 : 256;
        ColouredElement *new_elements;
        while (new_cap < pool->used + needed) new_cap *= 2;
        new_elements = realloc(pool->elements, new_cap * sizeof(ColouredElement));
        if (!new_elements) return 0;
        pool->elements = new_elements;
        pool->capacity = new_cap;
    }
    return 1;
}

NanoStatus nanocolour_read_file(const char *filename, char **contents_out, size_t *length_out) {
    FILE *f = fopen(filename, "rb");
    char *buf;
    size_t length;

    if (!contents_out || !length_out) return NANO_ERROR_INVALID_ARG;
    *contents_out = NULL;
    *length_out = 0;

    if (!f) return NANO_ERROR_FILE;
    fseek(f, 0, SEEK_END);
    length = (size_t)ftell(f);
    fseek(f, 0, SEEK_SET);
    buf = malloc(length + 1);
    if (!buf) {
        fclose(f);
        return NANO_ERROR_NOMEM;
    }
    if (fread(buf, 1, length, f) != length) {
        free(buf);
        fclose(f);
        return NANO_ERROR_FILE;
    }
    buf[length] = '\0';
    fclose(f);
    *contents_out = buf;
    *length_out = length;
    return NANO_OK;
}

NanoStatus nanocolour_colour_file(char *contents, size_t length, const Syntax *syntax, ColouredFile **file_out) {
    SyntaxInternal *si = (SyntaxInternal *)syntax;
    ColouredFile *cf;
    size_t line_count = 0;
    size_t i;
    char **line_ptrs = NULL;
    size_t *line_lens = NULL;
    size_t cur_line = 0;
    char *p;
    char *end;
    SyntaxRuleInternal *current_multi_rule = NULL;
    PackedStyle default_packed;
    Style default_style;
    size_t l;
    NanoStatus status = NANO_OK;
    char *line_text = NULL;
    size_t line_text_cap = 0;
    PackedStyle *styles = NULL;
    size_t styles_cap = 0;
    ElementPool pool = {NULL, 0, 0};

    if (!file_out || !syntax) return NANO_ERROR_INVALID_ARG;
    *file_out = NULL;

    cf = calloc(1, sizeof(ColouredFile));
    if (!cf) return NANO_ERROR_NOMEM;

    cf->contents = contents;
    cf->length = length;
    default_style.fg = COLOUR_NORMAL;
    default_style.bg = COLOUR_NORMAL;
    default_style.bright = 0;
    default_packed = PACK_STYLE(default_style);

    for (i = 0; i < length; i++) {
        if (contents[i] == '\n') line_count++;
    }
    if (length > 0 && contents[length-1] != '\n') line_count++;
    cf->line_count = line_count;
    cf->lines = calloc(line_count, sizeof(ColouredLine));
    if (!cf->lines) { status = NANO_ERROR_NOMEM; goto error; }

    line_ptrs = malloc(line_count * sizeof(char *));
    line_lens = malloc(line_count * sizeof(size_t));
    if (!line_ptrs || !line_lens) { status = NANO_ERROR_NOMEM; goto error; }
    
    p = contents;
    end = contents + length;
    while (p < end && cur_line < line_count) {
        char *next;
        line_ptrs[cur_line] = p;
        next = memchr(p, '\n', end - p);
        if (next) {
            line_lens[cur_line] = next - p;
            p = next + 1;
        } else {
            line_lens[cur_line] = end - p;
            p = end;
        }
        cf->lines[cur_line].line_number = cur_line + 1;
        cur_line++;
    }

    for (l = 0; l < line_count; l++) {
        size_t len = line_lens[l];
        size_t r_idx;

        if (len + 1 > line_text_cap) {
            size_t new_cap = line_text_cap ? line_text_cap * 2 : 128;
            char *new_text;
            while (new_cap < len + 1) new_cap *= 2;
            new_text = realloc(line_text, new_cap);
            if (!new_text) { status = NANO_ERROR_NOMEM; goto error; }
            line_text = new_text;
            line_text_cap = new_cap;
        }
        if (len > styles_cap) {
            size_t new_cap = styles_cap ? styles_cap * 2 : 128;
            PackedStyle *new_styles;
            while (new_cap < len) new_cap *= 2;
            new_styles = realloc(styles, new_cap * sizeof(PackedStyle));
            if (!new_styles) { status = NANO_ERROR_NOMEM; goto error; }
            styles = new_styles;
            styles_cap = new_cap;
        }

        memcpy(line_text, line_ptrs[l], len);
        line_text[len] = '\0';

        for (i = 0; i < len; i++) styles[i] = default_packed;

        if (current_multi_rule) {
            regmatch_t pmatch;
            PackedStyle multi_packed = PACK_STYLE(current_multi_rule->style);
            for (i = 0; i < len; i++) styles[i] = multi_packed;
            if (regexec(&current_multi_rule->re_end, line_text, 1, &pmatch, 0) == 0) {
                for (i = pmatch.rm_eo; i < len; i++) styles[i] = default_packed;
                current_multi_rule = NULL;
            }
        }

        for (r_idx = 0; r_idx < si->rule_count; r_idx++) {
            SyntaxRuleInternal *rule = &si->rules[r_idx];
            PackedStyle rule_packed = PACK_STYLE(rule->style);
            if (rule->type == RULE_SINGLE) {
                regmatch_t pmatch;
                int offset = 0;
                while (regexec(&rule->re_start, line_text + offset, 1, &pmatch, 0) == 0) {
                    int start = offset + (int)pmatch.rm_so;
                    int end_m = offset + (int)pmatch.rm_eo;
                    for (i = (size_t)start; i < (size_t)end_m; i++) styles[i] = rule_packed;
                    if (pmatch.rm_so == pmatch.rm_eo) offset++;
                    else offset = end_m;
                    if (offset >= (int)len) break;
                }
            } else {
                regmatch_t pmatch_s;
                int offset = 0;
                while (regexec(&rule->re_start, line_text + offset, 1, &pmatch_s, 0) == 0) {
                    int start = offset + pmatch_s.rm_so;
                    int start_end = offset + pmatch_s.rm_eo;
                    current_multi_rule = rule;
                    for (i = (size_t)start; i < len; i++) styles[i] = rule_packed;
                    
                    {
                        regmatch_t pmatch_e;
                        if (regexec(&rule->re_end, line_text + start_end, 1, &pmatch_e, 0) == 0) {
                            int end_m = start_end + pmatch_e.rm_eo;
                            for (i = (size_t)end_m; i < len; i++) styles[i] = default_packed;
                            current_multi_rule = NULL;
                            offset = end_m;
                        } else {
                            break;
                        }
                    }
                    if (offset >= (int)len) break;
                }
            }
        }

        if (len > 0) {
            size_t elem_count = 0;
            for (i = 0; i < len; i++) {
                if (i == 0 || styles[i] != styles[i-1]) {
                    elem_count++;
                }
            }
            if (!grow_pool(&pool, elem_count)) { status = NANO_ERROR_NOMEM; goto error; }
            
            cf->lines[l].element_count = elem_count;
            /* Store offset temporarily. +1 to avoid NULL if used is 0. */
            cf->lines[l].elements = (ColouredElement *)(pool.used + 1);
            {
                size_t e = 0;
                for (i = 0; i < len; i++) {
                    if (i == 0 || styles[i] != styles[i-1]) {
                        ColouredElement *el = &pool.elements[pool.used + e];
                        el->x_pos = i;
                        el->text_start = line_ptrs[l] + i;
                        unpack_style(styles[i], &el->style);
                        if (e > 0) {
                            pool.elements[pool.used + e - 1].text_length = i - pool.elements[pool.used + e - 1].x_pos;
                        }
                        e++;
                    }
                }
                pool.elements[pool.used + e - 1].text_length = len - pool.elements[pool.used + e - 1].x_pos;
                pool.used += elem_count;
            }
        }
    }

    /* Fix up pointers after all lines processed and pool is final */
    for (l = 0; l < line_count; l++) {
        if (cf->lines[l].elements) {
            size_t offset = (size_t)cf->lines[l].elements - 1;
            cf->lines[l].elements = &pool.elements[offset];
        }
    }

    free(line_ptrs);
    free(line_lens);
    free(line_text);
    free(styles);
    cf->element_pool = pool.elements;
    *file_out = cf;
    return NANO_OK;

error:
    free(line_ptrs);
    free(line_lens);
    free(line_text);
    free(styles);
    free(pool.elements);
    nanocolour_free_coloured_file(cf);
    return status;
}

void nanocolour_free_coloured_file(ColouredFile *file) {
    if (!file) return;
    free(file->lines);
    free(file->element_pool);
    free(file);
}
