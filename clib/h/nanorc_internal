#ifndef NANORC_INTERNAL_H
#define NANORC_INTERNAL_H

#include <stddef.h>

#ifdef FORTIFY
#include "Fortify/fortify.h"
#endif

#include "RegEx/regex.h"
#include "nanocolour.h"

/* Norcroft C requires C89: declarations at top of block */

/* Internal rule structure with compiled regexes */
typedef struct {
    RuleType type;
    regex_t re_start;
    regex_t re_end; /* Only for RULE_MULTI */
    Style style;
    int icase;
} SyntaxRuleInternal;

typedef struct {
    char *name;
    char *syntax_regex;
    char *magic_regex;
    size_t rule_count;
    SyntaxRuleInternal *rules;
} SyntaxInternal;

/* Shared helper for string comparison */
int my_strcasecmp(const char *s1, const char *s2);
int my_strncasecmp(const char *s1, const char *s2, size_t n);
char *my_strdup(const char *s);

#endif /* NANORC_INTERNAL_H */
