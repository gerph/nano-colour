#ifndef NANOCOLOUR_H
#define NANOCOLOUR_H

#include <stddef.h>

typedef enum {
    NANO_OK = 0,
    NANO_ERROR_NOMEM,
    NANO_ERROR_FILE,
    NANO_ERROR_REGEX,
    NANO_ERROR_INVALID_ARG
} NanoStatus;

typedef enum {
    COLOUR_BLACK = 0,
    COLOUR_RED = 1,
    COLOUR_GREEN = 2,
    COLOUR_YELLOW = 3,
    COLOUR_BLUE = 4,
    COLOUR_MAGENTA = 5,
    COLOUR_CYAN = 6,
    COLOUR_WHITE = 7,
    COLOUR_NORMAL = 9
} Colour;

typedef struct {
    Colour fg;
    Colour bg;
    int bright;
} Style;

typedef struct {
    int x_pos;
    const char *text_start;
    size_t text_length;
    Style style;
} ColouredElement;

typedef struct {
    int line_number;
    size_t element_count;
    ColouredElement *elements;
} ColouredLine;

typedef struct {
    char *contents;
    size_t length;
    size_t line_count;
    ColouredLine *lines;
} ColouredFile;

typedef enum {
    RULE_SINGLE,
    RULE_MULTI
} RuleType;

typedef struct Syntax_s Syntax;

/* Function prototypes */

/**
 * Reads a file into a single memory block.
 * The returned pointer must be freed by the caller.
 */
NanoStatus nanocolour_read_file(const char *filename, char **contents_out, size_t *length_out);

/**
 * Parses a single nanorc file into a Syntax structure.
 * Includes are ignored.
 */
NanoStatus nanocolour_parse_rc(const char *filename, Syntax **syntax_out);

/**
 * Colours a file content using the provided syntax rules.
 */
NanoStatus nanocolour_colour_file(char *contents, size_t length, const Syntax *syntax, ColouredFile **file_out);

/**
 * Frees a Syntax structure.
 */
void nanocolour_free_syntax(Syntax *syntax);

/**
 * Frees a ColouredFile structure.
 */
void nanocolour_free_coloured_file(ColouredFile *file);

#endif /* NANOCOLOUR_H */
